# Identidad de esta máquina (único en todo el sistema)
MACHINE_ID=water-001

# Modo de hardware: "real" (Raspberry Pi con GPIO) o "mock" (PC, tests, simulador)
HARDWARE_MODE=mock

# Bus de mensajes: "memory" (in-process, para simulador) o "mqtt" (broker real)
BUS_MODE=memory

# === MQTT (solo si BUS_MODE=mqtt) ===
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_TLS=false
MQTT_USERNAME=
MQTT_PASSWORD=

# === Calibración del caudalímetro ===
# YF-S201 publica ~450 pulsos por litro. Recalibrar midiendo agua real.
PULSES_PER_LITER=450

# === Pinout (BCM numbering) ===
# Solo aplica si HARDWARE_MODE=real
GPIO_FLOW_METER=17
GPIO_VALVE=23
GPIO_PUMP=24
GPIO_LED=18

# Lógica del relé: si tu placa activa con LOW, deja en true. Si activa con HIGH, false.
RELAY_ACTIVE_LOW=true

# === Tiempos de seguridad ===
# Tiempo máximo total de un dispensado antes de abortar (segundos)
DISPENSE_TIMEOUT_S=120
# Si pasan estos segundos sin recibir un pulso → atasco/sin agua → abortar
NO_FLOW_TIMEOUT_S=5
# Frecuencia de reportes de progreso al backend
PROGRESS_INTERVAL_MS=500
# Frecuencia de heartbeat al backend
HEARTBEAT_INTERVAL_S=30
